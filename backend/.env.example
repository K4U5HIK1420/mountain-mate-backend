## Server
PORT=5000
NODE_ENV=development

## Supabase (Auth + Postgres)
SUPABASE_URL=
# Server-side key (keep secret, NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=
# Data store switch:
# - mongo: use existing Mongoose models (default)
# - supabase: use Supabase Postgres tables for partner add/list/update (incremental migration)
DATA_STORE=mongo
# Optional: set to match your project's JWT issuer (recommended)
# Example: https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_ISSUER=
# Optional: most projects use "authenticated"
SUPABASE_JWT_AUDIENCE=authenticated

## Legacy MongoDB (during migration)
MONGO_URI=
JWT_SECRET=

## Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

## Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

